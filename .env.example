# ─── App ───────────────────────────────────────────
APP_PORT=8080
APP_ENV=development          # development | production

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_secret_at_least_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ─── gRPC Downstream ───────────────────────────────
GRPC_AUTH_ADDR=localhost:50051    # velotrax-auth-go
GRPC_CORE_ADDR=localhost:50052    # velotrax-core-go

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=info               # debug | info | warn | error

# ─── CORS ──────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000   # velotrax-portal (Next.js)
